@unpublished{li2026treematchrl,
  selected = {true},
  title = {TreeMatch-RL: Tree-based Distribution Matching Online RL for Diverse and Efficient Diffusion Model Alignment},
  author = {Jiaming Li and C. Zhu},
  year = {2026},
  journal = {Manuscript targeting NeurIPS 2026},
  abstract = {We study diversity degradation in reinforcement learning based alignment of diffusion models and propose TreeMatch-RL, a tree-based distribution matching framework for online optimization. The method introduces a Softmax-TB objective for global flow balance without explicit partition function estimation and combines it with adaptive SDE bifurcation over a multi-branch tree sampler. The resulting framework mitigates mode collapse while preserving high-fidelity generation and keeping inference overhead under control.},
  description = {First-author manuscript proposing a GFlowNet-inspired alignment framework with Softmax-TB loss and adaptive tree sampling to reduce mode collapse in diffusion reinforcement learning.},
  keywords = {Controllable AIGC, Diffusion Models, Reinforcement Learning, Alignment}
}

@article{yu2026i2e,
  selected = {true},
  title = {I2E: From Image Pixels to Actionable Interactive Environments for Text-Guided Image Editing},
  author = {J. Yu and J. Xiao and C. Zhu and Jiaming Li and J. Li and H. Deng and X. Wang and G. Jia and J. Li and Z. Ma and X. Bai and B. Zhou},
  year = {2026},
  month = jan,
  journal = {arXiv preprint arXiv:2601.03741},
  url = {https://arxiv.org/abs/2601.03741},
  abstract = {I2E converts image pixels into actionable interactive environments for compositional image editing driven by natural language instructions. The framework integrates structured perception, reasoning, and action execution so that a vision-language-action agent can decompose editing intentions into atomic operations and produce more faithful and physically aware edits. Extensive experiments on I2E-BENCH validate the effectiveness of the proposed pipeline.},
  description = {Fourth-author work under review at ACL 2026; I contributed to the design and implementation of the vision-language-action agent and led experimental validation on I2E-BENCH.},
  keywords = {Multimodal Large Models, Vision-Language-Action, Image Editing, Agents}
}
